---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---

<Layout
	title="Page Not Found | Maria"
	description="404 page for the Maria Astro portfolio theme."
	showFooterCta={false}
	noindex={true}
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="not-found-page">
		<SiteHeader />

		<main id="main-content" class="not-found-main">
			<header class="not-found-header">
				<h1>Page not found.</h1>
			</header>
			<p class="intro">
				The link may be outdated, the page may have moved, or the URL may have been typed
				incorrectly.
			</p>

			<div class="actions">
				<a href="/">
					<span>Go to homepage</span>
					<span aria-hidden="true">-&gt;</span>
				</a>
			</div>
		</main>
	</div>
</Layout>

<style>
	.not-found-page {
		width: min(calc(100% - 3rem), 62rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.not-found-main {
		padding: 5rem 0 0;
	}

	.not-found-header {
		max-width: 46rem;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.5rem, 4.2vw, 3.9rem);
		line-height: 1.05;
		letter-spacing: -0.05em;
		font-weight: 800;
	}

	.intro {
		margin: 1.5rem 0 0;
		max-width: 46rem;
		font-size: 1.05rem;
		line-height: 1.75;
		color: var(--muted-foreground);
	}

	.actions {
		display: flex;
		margin-top: 2.5rem;
	}

	.actions a {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		min-height: 48px;
		padding: 0.85rem 1.1rem;
		border: 1px solid var(--control-border);
		border-radius: 999px;
		font-size: 1rem;
		font-weight: 700;
		color: inherit;
		text-decoration: none;
		transition:
			transform 120ms ease,
			border-color 120ms ease,
			background-color 120ms ease;
	}

	.actions a:hover,
	.actions a:focus-visible {
		transform: translateY(-1px);
		background: var(--muted);
		border-color: var(--border-strong);
	}

	@media (max-width: 720px) {
		.not-found-page {
			width: min(calc(100% - 1.5rem), 62rem);
			padding-top: 1rem;
		}

		.not-found-main {
			padding-top: 4rem;
		}
	}
</style>
