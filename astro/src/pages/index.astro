---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';

const allPublications = await getCollection('publications');
const recent = allPublications
  .filter(p => p.data.year)
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0))
  .slice(0, 4);

const allNews = await getCollection('news');
const recentNews = allNews
  .sort((a, b) => b.id.localeCompare(a.id))
  .slice(0, 3);

const homePage = await getEntry('pages', 'home');
const home = homePage!.data;

const allPeople = await getCollection('people');
const keyToName: Record<string, string> = {};
for (const p of allPeople) {
  const k = (p.data.key ?? p.id).toLowerCase();
  keyToName[k] = `${p.data.first_name} ${p.data.last_name}`;
}
const resolveAuthor = (a: string) => keyToName[a.toLowerCase()] ?? a;
---

<Layout
	title={home.title ?? 'VID Lab'}
	description={home.hero_text ?? ''}
>
	<a class="skip-link" href="#main-content">Skip to content</a>

	<div class="page" style="--page-accent: #dcff68">
		<SiteHeader />

		<main id="main-content">
			<section class="hero" id="top">
				<div class="hero-copy">
					{home.hero_text && <p class="hero-text">{home.hero_text}</p>}
					{home.hero_note && <p class="hero-note">{home.hero_note}</p>}
					<div class="hero-actions">
						{home.cta_primary_label && home.cta_primary_href && (
							<a class="btn-primary" href={home.cta_primary_href}>{home.cta_primary_label}</a>
						)}
						{home.cta_secondary_label && home.cta_secondary_href && (
							<a class="btn-secondary" href={home.cta_secondary_href}>{home.cta_secondary_label}</a>
						)}
					</div>
					<div class="hero-affiliation">
						<img class="liu-logo brand-logo-dark"  src="/LiU_primary_black.png" alt="Linköping University" height="36" onerror="this.style.display='none'" />
						<img class="liu-logo brand-logo-light" src="/LiU_primary_white.png" alt="Linköping University" height="36" onerror="this.style.display='none'" />
					</div>
				</div>
				<div class="hero-image-wrap">
					<img
						class="hero-image"
						src={home.hero_image ?? '/mosaic.png'}
						alt={home.hero_image_alt ?? ''}
						loading="eager"
						decoding="async"
					/>
				</div>
			</section>

			<section class="recent-pubs animate-up" id="publications">
				<header class="section-header">
					<p class="eyebrow">Recent work</p>
					<h2>Latest publications</h2>
				</header>
				<div class="pub-grid">
					{recent.map((pub, i) => (
						<a class="pub-card animate-up" href={`/publications/${pub.id}`} style={`--delay:${i * 80}ms`}>
							<p class="pub-year">{pub.data.year}</p>
							<h3 class="pub-title">{pub.data.title}</h3>
							{pub.data.authors && (
								<p class="pub-authors">{pub.data.authors.map(resolveAuthor).join(', ')}</p>
							)}
							{pub.data['journal-short'] && (
								<p class="pub-venue">{pub.data['journal-short']}</p>
							)}
							{pub.data.publisherURL && (
								<span class="pub-link">View paper →</span>
							)}
						</a>
					))}
				</div>
				<div class="see-all">
					<a class="btn-secondary" href="/publications">All publications</a>
				</div>
			</section>

			<section class="recent-news animate-up" id="news">
				<header class="section-header">
					<p class="eyebrow">What's happening</p>
					<h2>Latest news</h2>
				</header>
				<div class="news-list">
					{recentNews.map((item, i) => {
						const dateMatch = item.id.match(/^(\d{4}-\d{2}-\d{2})/);
						const date = dateMatch
							? new Date(dateMatch[1]).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
							: '';
						const href = `/news/${item.id}`;
						return (
							<a class="news-item animate-up" href={href} style={`--delay:${i * 80}ms`}>
								{item.data['lead-image'] && (
									<div class="news-img-wrap">
										<img
											src={item.data['lead-image']}
											alt={item.data['lead-image-alt-text'] ?? ''}
											loading="lazy"
										/>
									</div>
								)}
								<div class="news-body">
									{date && <p class="news-date">{date}</p>}
									<h3 class="news-title">{item.data.title}</h3>
								</div>
							</a>
						);
					})}
				</div>
				<div class="see-all">
					<a class="btn-secondary" href="/news">All news</a>
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.page {
		position: relative;
		width: min(calc(100% - 3rem), 78rem);
		margin: 0 auto;
		padding: 1.25rem 0 5rem;
	}

	.eyebrow {
		font-family: var(--font-mono);
		font-size: 0.82rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--muted-foreground);
		margin: 0;
	}

	.hero {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
		padding: 7rem 0 6.5rem;
	}

	.float-anim {
		animation: float 5s ease-in-out infinite;
	}

	.hero-image-wrap {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.hero-logo {
		margin: 0.75rem 0 1.5rem;
	}

	.hero-logo-img {
		height: clamp(3.5rem, 8vw, 6rem);
		width: auto;
		display: block;
	}

	.hero-image {
		width: 100%;
		max-width: 36rem;
		height: auto;
		border-radius: 0;
		box-shadow: none;
	}

	.hero-affiliation {
		margin-top: 2rem;
		display: flex;
		align-items: center;
	}

	.liu-logo {
		height: 36px;
		width: auto;
	}

	h2 {
		margin: 0.5rem 0 0;
		font-weight: 800;
		letter-spacing: -0.04em;
		font-size: clamp(1.8rem, 3vw, 2.8rem);
		line-height: 1.06;
		color: var(--foreground);
	}

	.hero-text {
		max-width: 38rem;
		margin: 1.5rem 0 0;
		font-size: 1.2rem;
		line-height: 1.55;
	}

	.hero-note {
		max-width: 40rem;
		margin: 1rem 0 0;
		font-size: 1.2rem;
		line-height: 1.55;
		color: var(--muted-foreground);
		font-style: italic;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		margin-top: 2rem;
		flex-wrap: wrap;
	}

	.btn-primary,
	.btn-secondary {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		min-height: 48px;
		padding: 0.85rem 1.4rem;
		border-radius: 999px;
		font-size: 1rem;
		font-weight: 700;
		text-decoration: none;
		transition: transform 120ms ease, background-color 120ms ease, border-color 120ms ease, color 120ms ease;
	}

	.btn-primary {
		background: var(--foreground);
		color: var(--background);
		border: 1px solid var(--foreground);
	}

	.btn-primary:hover {
		transform: translateY(-1px);
		background: var(--accent);
		border-color: var(--accent);
		color: #1a0a28;
	}

	.btn-secondary {
		background: transparent;
		color: var(--foreground);
		border: 1px solid var(--control-border);
	}

	.btn-secondary:hover {
		transform: translateY(-1px);
		border-color: var(--accent);
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 8%, transparent);
	}

	.recent-pubs {
		padding-top: 2rem;
		border-top: 1px solid var(--border);
	}

	.section-header {
		margin-bottom: 2rem;
	}

	.section-header h2 {
		display: inline-block;
		position: relative;
	}

	.section-header h2::after {
		content: '';
		position: absolute;
		left: 0;
		bottom: -4px;
		width: 100%;
		height: 4px;
		background: var(--page-accent);
		border-radius: 2px;
	}

	.pub-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.pub-card {
		display: grid;
		align-content: start;
		gap: 0.5rem;
		padding: 1.5rem;
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: 1.35rem;
		transition: transform 140ms ease, box-shadow 140ms ease;
		text-decoration: none;
		color: inherit;
	}

	.pub-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-soft);
		border-color: var(--accent);
	}

	.pub-year {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--muted-foreground);
		margin: 0;
	}

	.pub-title {
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.3;
		letter-spacing: -0.02em;
		color: var(--foreground);
		margin: 0;
	}

	.pub-authors,
	.pub-venue {
		font-size: 0.88rem;
		line-height: 1.4;
		color: var(--muted-foreground);
		margin: 0;
	}

	.pub-venue {
		font-style: italic;
	}

	.pub-link {
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--foreground);
		text-decoration: none;
		margin-top: 0.25rem;
	}

	.pub-link:hover {
		text-decoration: underline;
	}

	.see-all {
		margin-top: 2rem;
		display: flex;
		justify-content: flex-start;
	}

	.recent-news {
		padding-top: 2rem;
		margin-top: 3rem;
		border-top: 1px solid var(--border);
	}

	.news-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.news-item {
		display: flex;
		flex-direction: column;
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: 1.25rem;
		overflow: hidden;
		transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
		text-decoration: none;
		color: inherit;
	}

	.news-item:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-soft);
		border-color: var(--accent);
	}

	.news-img-wrap {
		aspect-ratio: 16/9;
		overflow: hidden;
		background: var(--muted);
	}

	.news-img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.news-body {
		padding: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		flex: 1;
	}

	.news-date {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--muted-foreground);
		margin: 0;
	}

	.news-title {
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.35;
		letter-spacing: -0.02em;
		color: var(--foreground);
		margin: 0;
	}

	@media (max-width: 860px) {
		.hero {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.hero-image {
			max-width: 100%;
		}
	}

	@media (max-width: 720px) {
		.page {
			width: min(calc(100% - 1.5rem), 78rem);
			padding-top: 1rem;
		}

		.hero {
			padding: 4rem 0 4.5rem;
		}

		.hero-text, .hero-note {
			font-size: 1.05rem;
		}

		.pub-grid {
			grid-template-columns: 1fr;
		}

		.news-list {
			grid-template-columns: 1fr;
		}
	}
</style>
