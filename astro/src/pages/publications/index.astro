---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const allPeople = await getCollection('people');
const keyToName: Record<string, string> = {};
for (const person of allPeople) {
  const k = (person.data.key ?? person.id).toLowerCase();
  keyToName[k] = `${person.data.first_name} ${person.data.last_name}`;
}
const resolveAuthor = (a: string) => keyToName[a.toLowerCase()] ?? a;

const allPubs = await getCollection('publications');
const sorted = allPubs
  .filter(p => p.data.year)
  .sort((a, b) => (b.data.year ?? 0) - (a.data.year ?? 0));

const years = [...new Set(sorted.map(p => p.data.year!))].sort((a, b) => b - a);

const rawTypes = [...new Set(sorted.map(p => (p.data.type ?? 'paper').trim()))];
const typeOrder = ['paper', 'thesis', 'abstract', 'poster', 'preprint', 'commentary'];
const types = [...typeOrder.filter(t => rawTypes.includes(t)), ...rawTypes.filter(t => !typeOrder.includes(t))];

const typeLabel: Record<string, string> = {
  paper: 'Paper', thesis: 'Thesis', abstract: 'Abstract',
  poster: 'Poster', preprint: 'Preprint', commentary: 'Commentary',
};
---

<Layout title="Publications | Visualization Collective" description="Research publications from the Visualization Collective at Linköping University.">
  <a class="skip-link" href="#main-content">Skip to content</a>
  <div class="page" style="--page-accent: #4ade80">
    <SiteHeader />
    <main id="main-content" class="pubs-main">
      <header class="pubs-hero">
        <p class="eyebrow">Research output</p>
        <h1>Publications</h1>
        <p class="intro">Papers, presentations, and conference proceedings from members of the Visualization Collective.</p>
      </header>

      <div class="filters" role="group" aria-label="Filter publications">
        <div class="filter-group">
          <span class="filter-label">Type</span>
          <button class="filter-btn active" data-filter="type" data-value="all">All</button>
          {types.map(t => (
            <button class="filter-btn" data-filter="type" data-value={t}>{typeLabel[t] ?? t}</button>
          ))}
        </div>
        <div class="filter-group">
          <span class="filter-label">Year</span>
          <button class="filter-btn active" data-filter="year" data-value="all">All</button>
          {years.map(y => (
            <button class="filter-btn" data-filter="year" data-value={String(y)}>{y}</button>
          ))}
        </div>
      </div>
      <p class="results-count" id="results-count" aria-live="polite"></p>

      <ul class="pub-list" id="pub-list">
        {sorted.map(pub => {
          const imgFile = pub.data.image_large ?? pub.data.image;
          const pubType = (pub.data.type ?? 'paper').trim();
          return (
            <li class="pub-item" data-year={String(pub.data.year)} data-type={pubType}>
              <a class:list={['pub-thumb-wrap', !imgFile && 'pub-thumb-empty']} href={`/publications/${pub.id}`}>
                {imgFile && (
                  <img class="pub-thumb" src={`/publication-images/${imgFile}`}
                    alt={pub.data.shortname ?? pub.data.title} loading="lazy" decoding="async" />
                )}
              </a>
              <div class="pub-main">
                <h3 class="pub-title">
                  <a href={`/publications/${pub.id}`}>{pub.data.title}</a>
                </h3>
                {pub.data.authors && (
                  <p class="pub-authors">{pub.data.authors.map(resolveAuthor).join(', ')}</p>
                )}
                <div class="pub-meta">
                  {(pub.data['journal-short'] ?? pub.data.bib?.booktitle) && (
                    <span class="pub-venue">{pub.data['journal-short'] ?? pub.data.bib?.booktitle}</span>
                  )}
                  {pub.data.year && <span class="pub-year-badge">{pub.data.year}</span>}
                  <span class={`pub-type-badge type-${pubType}`}>{typeLabel[pubType] ?? pubType}</span>
                </div>
              </div>
              <div class="pub-actions">
                <a class="pub-detail-link" href={`/publications/${pub.id}`}>Details</a>
                {pub.data.publisherURL && (
                  <a class="pub-external" href={pub.data.publisherURL} target="_blank" rel="noopener">↗</a>
                )}
              </div>
            </li>
          );
        })}
      </ul>
      <p class="no-results" id="no-results" style="display:none">No publications match the selected filters.</p>
    </main>
  </div>
</Layout>

<script>
  const list = document.getElementById('pub-list')!;
  const items = Array.from(list.querySelectorAll<HTMLElement>('.pub-item'));
  const noResults = document.getElementById('no-results')!;
  const countEl = document.getElementById('results-count')!;
  const state: Record<string, string> = { type: 'all', year: 'all' };

  function applyFilters() {
    let visible = 0;
    for (const item of items) {
      const show = (state.type === 'all' || item.dataset.type === state.type)
                && (state.year === 'all' || item.dataset.year === state.year);
      item.style.display = show ? '' : 'none';
      if (show) visible++;
    }
    noResults.style.display = visible === 0 ? '' : 'none';
    countEl.textContent = visible === items.length ? '' : `${visible} of ${items.length} publications`;
  }

  document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;
      state[filter] = btn.dataset.value!;
      btn.closest('.filter-group')!.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilters();
    });
  });
</script>

<style>
  .page { width: min(calc(100% - 12rem), 64rem); margin: 0 auto; padding: 1.25rem 0 5rem; }
  .pubs-main { padding-top: 4.5rem; }
  .eyebrow { font-family: var(--font-mono); font-size: 0.82rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #1a1a1a; background: var(--page-accent); padding: 0.1rem 0.4rem; border-radius: 0.2rem; margin: 0; width: fit-content; display: block; }
  h1 { margin: 0.5rem 0 0; font-weight: 800; letter-spacing: -0.05em; font-size: clamp(2.6rem, 4.6vw, 4.4rem); line-height: 1.03; color: var(--foreground); display: inline-block; position: relative; }
  h1::after { content: ''; position: absolute; left: 0; bottom: -6px; width: 100%; height: 5px; background: var(--page-accent); border-radius: 3px; }
  .intro { max-width: 42rem; margin: 1rem 0 0; font-size: 1.05rem; line-height: 1.75; color: var(--muted-foreground); }

  .filters { margin-top: 2.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
  .filter-group { display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem; }
  .filter-label { font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted-foreground); width: 3.5rem; flex-shrink: 0; }
  .filter-btn { padding: 0.3rem 0.75rem; border: 1px solid var(--control-border); border-radius: 999px; background: transparent; font-size: 0.82rem; font-weight: 600; color: var(--muted-foreground); cursor: pointer; transition: background 100ms ease, color 100ms ease, border-color 100ms ease; }
  .filter-btn:hover { background: color-mix(in srgb, var(--accent) 10%, transparent); color: var(--accent); border-color: var(--accent); }
  .filter-btn.active { background: var(--foreground); border-color: var(--foreground); color: var(--background); }
  .results-count { font-family: var(--font-mono); font-size: 0.78rem; color: var(--muted-foreground); margin: 1rem 0 0; min-height: 1.2em; }

  .pub-list { list-style: none; margin: 0.5rem 0 0; padding: 0; }
  .pub-item { display: flex; align-items: center; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid var(--border); }
  .pub-item:first-child { border-top: 1px solid var(--border); }

  .pub-thumb-wrap { flex-shrink: 0; width: 7rem; height: 5rem; border-radius: 0.6rem; overflow: hidden; background: var(--muted); border: 1px solid var(--border); display: block; text-decoration: none; transition: opacity 120ms ease; }
  .pub-thumb-wrap:hover { opacity: 0.85; }
  .pub-thumb-empty { cursor: default; pointer-events: none; }
  .pub-thumb { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }

  .pub-main { flex: 1; display: grid; gap: 0.3rem; min-width: 0; }
  .pub-title { font-size: 0.97rem; font-weight: 600; line-height: 1.4; color: var(--foreground); margin: 0; }
  .pub-title a { color: inherit; text-decoration: none; transition: color 120ms ease; }
  .pub-title a:hover { color: var(--accent); }
  .pub-authors { font-size: 0.85rem; color: var(--muted-foreground); margin: 0; line-height: 1.4; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .pub-meta { display: flex; flex-wrap: wrap; gap: 0.4rem 0.75rem; align-items: center; }
  .pub-venue { font-size: 0.82rem; font-style: italic; color: var(--muted-foreground); }
  .pub-year-badge { font-family: var(--font-mono); font-size: 0.75rem; font-weight: 700; color: var(--muted-foreground); letter-spacing: 0.04em; }
  .pub-type-badge { font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.15rem 0.5rem; border-radius: 999px; background: var(--type-bg, var(--muted)); color: var(--type-color, var(--muted-foreground)); }
  .type-paper       { --type-bg: #dbeafe; --type-color: #1d4ed8; }
  .type-thesis      { --type-bg: #ede9fe; --type-color: #6d28d9; }
  .type-abstract    { --type-bg: #ffedd5; --type-color: #9a3412; }
  .type-poster      { --type-bg: #fce7f3; --type-color: #9d174d; }
  .type-preprint    { --type-bg: #fefce8; --type-color: #854d0e; }
  .type-commentary  { --type-bg: #d1fae5; --type-color: #065f46; }
  :root[data-theme='dark'] .type-paper      { --type-bg: #1e3a5f; --type-color: #93c5fd; }
  :root[data-theme='dark'] .type-thesis     { --type-bg: #3b1f6e; --type-color: #c4b5fd; }
  :root[data-theme='dark'] .type-abstract   { --type-bg: #431407; --type-color: #fdba74; }
  :root[data-theme='dark'] .type-poster     { --type-bg: #500724; --type-color: #fbcfe8; }
  :root[data-theme='dark'] .type-preprint   { --type-bg: #422006; --type-color: #fde68a; }
  :root[data-theme='dark'] .type-commentary { --type-bg: #064e3b; --type-color: #6ee7b7; }

  .pub-actions { flex-shrink: 0; display: flex; flex-direction: column; align-items: flex-end; gap: 0.4rem; }
  .pub-detail-link, .pub-external { font-size: 0.82rem; font-weight: 600; color: var(--foreground); text-decoration: none; padding: 0.25rem 0.65rem; border: 1px solid var(--control-border); border-radius: 999px; transition: background 100ms ease; white-space: nowrap; }
  .pub-detail-link:hover, .pub-external:hover { background: color-mix(in srgb, var(--accent) 10%, transparent); border-color: var(--accent); color: var(--accent); }
  .no-results { text-align: center; padding: 3rem 0; color: var(--muted-foreground); }

  @media (max-width: 640px) {
    .page { width: min(calc(100% - 1.5rem), 78rem); padding-top: 1rem; }
    .pubs-main { padding-top: 4rem; }
    .pub-thumb-wrap { display: none; }
    .filter-label { width: 2.5rem; }
  }
</style>
