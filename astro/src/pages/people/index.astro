---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const allPeople = await getCollection('people', ({ id }) => !id.startsWith('alumni/'));
const alumni = await getCollection('people', ({ id }) => id.startsWith('alumni/'));

const roleOrder: Record<string, number> = {
  faculty: 0, postdoc: 1, researcher: 2, phdstudent: 3, msstudent: 4, staff: 5,
};
const roleLabel: Record<string, string> = {
  faculty: 'Faculty', postdoc: 'Postdoctoral Researcher', researcher: 'Researcher',
  phdstudent: 'PhD Student', msstudent: 'MS Student', staff: 'Staff',
};

const active = allPeople.sort((a, b) => {
  const rA = roleOrder[a.data.role] ?? 99;
  const rB = roleOrder[b.data.role] ?? 99;
  if (rA !== rB) return rA - rB;
  return a.data.last_name.localeCompare(b.data.last_name);
});
---

<Layout title="People | VID Lab" description="Meet the researchers and students of the VID Lab at Linköping University.">
  <a class="skip-link" href="#main-content">Skip to content</a>
  <div class="page">
    <SiteHeader />
    <main id="main-content" class="people-main">
      <header class="people-hero">
        <p class="eyebrow">Our team</p>
        <h1>People</h1>
        <p class="intro">A multidisciplinary group of researchers and students working at the intersection of data, design, and technology.</p>
      </header>

      <section class="people-list" aria-label="Active members">
        {active.map(person => {
          const key = person.data.key ?? person.id;
          const photoSrc = `/photos/people/${key}.jpg`;
          const href = `/people/${key}`;
          return (
            <div class="person-row">
              <a class="person-photo-link" href={href} tabindex="-1" aria-hidden="true">
                <div class="person-photo-wrap">
                  <img
                    class="person-photo"
                    src={photoSrc}
                    alt={`${person.data.first_name} ${person.data.last_name}`}
                    loading="lazy"
                    onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                  />
                  <div class="person-photo-fallback" style="display:none">
                    {person.data.first_name[0]}{person.data.last_name[0]}
                  </div>
                </div>
              </a>
              <div class="person-info">
                <p class="person-role">{roleLabel[person.data.role] ?? person.data.role}</p>
                <h2 class="person-name"><a href={href}>{person.data.first_name} {person.data.last_name}</a></h2>
                {person.data.keywords && <p class="person-keywords">{person.data.keywords}</p>}
                <div class="person-links">
                  {person.data.email && <a class="person-link" href={`mailto:${person.data.email}`}>{person.data.email}</a>}
                  {person.data['personal-site'] && <a class="person-link" href={person.data['personal-site']} target="_blank" rel="noopener">Personal Site</a>}
                  {person.data.gs && <a class="person-link" href={person.data.gs} target="_blank" rel="noopener">Google Scholar</a>}
                  {person.data.orcid && <a class="person-link" href={`https://orcid.org/${person.data.orcid}`} target="_blank" rel="noopener">ORCID</a>}
                </div>
              </div>
            </div>
          );
        })}
      </section>

      {alumni.length > 0 && (
        <section class="alumni-section">
          <h2 class="alumni-heading">Alumni</h2>
          <ul class="alumni-list">
            {alumni
              .sort((a, b) => a.data.last_name.localeCompare(b.data.last_name))
              .map(person => (
                <li class="alumni-item">
                  <span class="alumni-name">{person.data.first_name} {person.data.last_name}</span>
                  {person.data.graduated && <span class="alumni-grad">{person.data.graduated}</span>}
                  {person.data['personal-site'] && (
                    <a href={person.data['personal-site']} target="_blank" rel="noopener">↗</a>
                  )}
                </li>
              ))}
          </ul>
        </section>
      )}
    </main>
  </div>
</Layout>

<style>
  .page { width: min(calc(100% - 3rem), 78rem); margin: 0 auto; padding: 1.25rem 0 5rem; }
  .people-main { padding-top: 4.5rem; }
  .eyebrow { font-family: var(--font-mono); font-size: 0.82rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted-foreground); margin: 0; }
  h1 { margin: 0.5rem 0 0; font-weight: 800; letter-spacing: -0.05em; font-size: clamp(2.6rem, 4.6vw, 4.4rem); line-height: 1.03; color: var(--foreground); }
  .intro { max-width: 42rem; margin: 1rem 0 0; font-size: 1.05rem; line-height: 1.75; color: var(--muted-foreground); }

  .people-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .person-row {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: start;
  }

  .person-photo-link {
    display: block;
    width: 100%;
  }

  .person-photo-wrap {
    width: 100%;
    max-width: 300px;
    aspect-ratio: 1;
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--muted);
    border: 1px solid var(--border);
    transition: border-color 140ms ease;
  }

  .person-photo-link:hover .person-photo-wrap {
    border-color: var(--accent);
  }

  .person-photo { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
  .person-photo-fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; font-weight: 800; color: var(--muted-foreground); text-transform: uppercase; }

  .person-info { display: flex; flex-direction: column; gap: 0.35rem; padding-top: 0.25rem; }
  .person-role { font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.07em; text-transform: uppercase; color: var(--muted-foreground); margin: 0; }
  h2.person-name { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.03em; color: var(--foreground); margin: 0 0 0.15rem; }
  h2.person-name a { color: inherit; text-decoration: none; transition: color 120ms ease; }
  h2.person-name a:hover { color: var(--accent); text-decoration: none; }
  .person-keywords { font-size: 0.95rem; color: var(--muted-foreground); margin: 0; line-height: 1.5; }

  .person-links { display: flex; flex-direction: column; gap: 0.2rem; margin-top: 0.75rem; }
  .person-link { font-size: 0.88rem; color: var(--muted-foreground); text-decoration: none; transition: color 120ms ease; }
  .person-link:hover { color: var(--accent); text-decoration: none; }

  .alumni-section { margin-top: 4rem; padding-top: 2.5rem; border-top: 1px solid var(--border); }
  h2.alumni-heading { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.04em; color: var(--foreground); margin: 0 0 1.5rem; }
  .alumni-list { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr)); gap: 0.5rem 2rem; }
  .alumni-item { display: flex; align-items: baseline; gap: 0.5rem; font-size: 0.95rem; padding: 0.35rem 0; border-bottom: 1px solid var(--border); }
  .alumni-name { font-weight: 600; color: var(--foreground); }
  .alumni-grad { font-size: 0.8rem; color: var(--muted-foreground); font-family: var(--font-mono); }
  .alumni-item a { font-size: 0.85rem; color: var(--muted-foreground); text-decoration: none; margin-left: auto; }
  .alumni-item a:hover { color: var(--foreground); }

  @media (max-width: 860px) {
    .people-list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .page { width: min(calc(100% - 1.5rem), 78rem); padding-top: 1rem; }
    .people-main { padding-top: 4rem; }
    .people-list { grid-template-columns: 1fr; }
  }
</style>
