---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import { siteConfig } from '../config/site';

const {
	title = siteConfig.title,
	description = siteConfig.description,
	showFooterCta = true,
	noindex = false,
	schema,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, siteConfig.siteUrl).toString();
const ogImageUrl = new URL(siteConfig.ogImage, siteConfig.siteUrl).toString();
const schemaData =
	schema ??
	[
		{
			'@context': 'https://schema.org',
			'@type': 'WebSite',
			name: siteConfig.name,
			url: siteConfig.siteUrl,
			description: siteConfig.description,
			inLanguage: siteConfig.locale,
		},
		{
			'@context': 'https://schema.org',
			'@type': 'Person',
			name: siteConfig.authorName,
			jobTitle: siteConfig.authorRole,
			url: siteConfig.siteUrl,
			email: siteConfig.email,
		},
	];
---

<!doctype html>
<html lang={siteConfig.locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="color-scheme" content="light dark" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="keywords" content={siteConfig.keywords.join(', ')} />
		<meta name="author" content={siteConfig.authorName} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content={siteConfig.name} />
		<meta property="og:locale" content={siteConfig.locale.replace('-', '_')} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:alt" content={siteConfig.title} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		<link
			rel="preload"
			href="/fonts/manrope-latin-wght-normal.woff2"
			as="font"
			type="font/woff2"
			crossorigin
		/>
		<title>{title}</title>
		<link rel="stylesheet" href="/cookie-consent.css" />
		<script type="application/ld+json" set:html={JSON.stringify(schemaData)}></script>
		<script is:inline>
			(() => {
				const storageKey = 'maria-theme';
				const root = document.documentElement;
				const storedTheme = localStorage.getItem(storageKey);
				const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches
					? 'dark'
					: 'light';
				root.dataset.theme = storedTheme === 'dark' || storedTheme === 'light' ? storedTheme : systemTheme;
			})();
		</script>
	</head>
	<body>
		<slot />
		<SiteFooter showCta={showFooterCta} />
		<script src="/cookie-consent.js" defer></script>
		<script is:inline>
			(() => {
				// Entrance animations
				const observer = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('in-view');
							observer.unobserve(entry.target);
						}
					});
				}, { threshold: 0.08, rootMargin: '0px 0px -32px 0px' });
				document.querySelectorAll('.animate-up').forEach(el => observer.observe(el));

				// Large background blobs
				const blobColors = ['#d19cec','#dcff68','#f472b6','#60a5fa','#4ade80','#fb923c'];
				const blobData = [];
				const blobs = [
					{ x: 15,  y: 10,  size: 600, colorIdx: 0, speed: 0.06 },
					{ x: 75,  y: 25,  size: 500, colorIdx: 1, speed: 0.10 },
					{ x: 30,  y: 55,  size: 650, colorIdx: 2, speed: 0.04 },
					{ x: 80,  y: 70,  size: 550, colorIdx: 3, speed: 0.08 },
					{ x: 10,  y: 80,  size: 480, colorIdx: 4, speed: 0.12 },
					{ x: 60,  y: 90,  size: 580, colorIdx: 5, speed: 0.05 },
				];

				blobs.forEach(({ x, y, size, colorIdx, speed }) => {
					const el = document.createElement('div');
					el.className = 'bg-blob';
					Object.assign(el.style, {
						width:       `${size}px`,
						height:      `${size}px`,
						left:        `calc(${x}vw - ${size / 2}px)`,
						top:         `calc(${y}vh - ${size / 2}px)`,
						background:  blobColors[colorIdx],
					});
					document.body.appendChild(el);
					blobData.push({ el, speed });
				});

				let ticking = false;
				window.addEventListener('scroll', () => {
					if (!ticking) {
						requestAnimationFrame(() => {
							const sy = window.scrollY;
							blobData.forEach(({ el, speed }) => {
								el.style.transform = `translateY(${-sy * speed}px)`;
							});
							ticking = false;
						});
						ticking = true;
					}
				}, { passive: true });

			})();
		</script>
		<script is:inline>
			(() => {
				const storageKey = 'maria-theme';
				const root = document.documentElement;
				const toggle = document.querySelector('[data-theme-toggle]');
				if (!toggle) {
					return;
				}

				const applyTheme = (theme) => {
					root.dataset.theme = theme;
					toggle.setAttribute('aria-pressed', String(theme === 'dark'));
					toggle.setAttribute(
						'aria-label',
						theme === 'dark' ? 'Switch to light mode' : 'Switch to dark mode',
					);
				};

				applyTheme(root.dataset.theme === 'dark' ? 'dark' : 'light');

				toggle.addEventListener('click', () => {
					const nextTheme = root.dataset.theme === 'dark' ? 'light' : 'dark';
					localStorage.setItem(storageKey, nextTheme);
					applyTheme(nextTheme);
				});

				const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
				mediaQuery.addEventListener('change', (event) => {
					if (localStorage.getItem(storageKey)) {
						return;
					}

					applyTheme(event.matches ? 'dark' : 'light');
				});
			})();
		</script>
	</body>
</html>

<style is:global>
	/* Ensure all page content is selectable */
	body, body * {
		-webkit-user-select: text !important;
		user-select: text !important;
	}

	/* Except interactive elements where none makes sense */
	button, [role="button"] {
		-webkit-user-select: none !important;
		user-select: none !important;
	}

	@font-face {
		font-family: 'Manrope Variable';
		font-style: normal;
		font-display: optional;
		font-weight: 200 800;
		src: url('/fonts/manrope-latin-wght-normal.woff2') format('woff2-variations');
		unicode-range:
			U+0000-00FF,
			U+0131,
			U+0152-0153,
			U+02BB-02BC,
			U+02C6,
			U+02DA,
			U+02DC,
			U+0304,
			U+0308,
			U+0329,
			U+2000-206F,
			U+20AC,
			U+2122,
			U+2191,
			U+2193,
			U+2212,
			U+2215,
			U+FEFF,
			U+FFFD;
	}

	:root {
		color-scheme: light;
		--background: #ffffff;
		--foreground: #171717;
		--muted: #f7f7f7;
		--muted-foreground: #676767;
		--page-accent: var(--page-accent);
		--border: #d9d9d9;
		--control-border: #d0d0d0;
		--border-strong: #232323;
		--card: #ffffff;
		--card-foreground: #171717;
		--ring: #171717;
		--selection: var(--page-accent);
		--accent: #d19cec;
		--accent-link: #5869d8;
		--shadow-soft: 0 18px 36px rgba(23, 23, 23, 0.08);
		--shadow-medium: 0 18px 40px rgba(23, 23, 23, 0.08);
		--shadow-large: 0 20px 50px rgba(23, 23, 23, 0.08);
		--icon-filter: none;
		--font-sans: 'Manrope Variable', 'Inter', 'Segoe UI', sans-serif;
		--font-mono:
			'SFMono-Regular',
			'SF Mono',
			'Roboto Mono',
			'IBM Plex Mono',
			'Segoe UI Mono',
			'Consolas',
			'Liberation Mono',
			monospace;
		--container: 72rem;
	}

	:root[data-theme='dark'] {
		color-scheme: dark;
		--background: #0d1014;
		--foreground: #f5f7fb;
		--muted: #171b22;
		--muted-foreground: #a3acb9;
		--border: #2a313c;
		--control-border: #495566;
		--border-strong: #e3e9f3;
		--card: #151a21;
		--card-foreground: #f5f7fb;
		--ring: #dce7ff;
		--selection: #c6f142;
		--accent: #d19cec;
		--accent-link: #9dacff;
		--shadow-soft: 0 18px 36px rgba(0, 0, 0, 0.35);
		--shadow-medium: 0 18px 40px rgba(0, 0, 0, 0.4);
		--shadow-large: 0 20px 50px rgba(0, 0, 0, 0.42);
		--icon-filter: invert(1) brightness(1.15);
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		min-height: 100vh;
		font-family: var(--font-sans);
		color: var(--foreground);
		background-color: var(--background);
		transition:
			background-color 180ms ease,
			color 180ms ease,
			border-color 180ms ease;
	}

	a {
		color: inherit;
	}

	img {
		display: block;
		max-width: 100%;
	}

	button,
	input,
	textarea {
		font: inherit;
	}

	button {
		background: none;
		border: 0;
		padding: 0;
	}

	:focus-visible {
		outline: 3px solid var(--ring);
		outline-offset: 3px;
	}

	::selection {
		background: #dcff68;
		color: #1a1a1a;
	}
	::-moz-selection {
		background: #dcff68;
		color: #1a1a1a;
	}

	.skip-link {
		position: absolute;
		left: 1rem;
		top: 1rem;
		z-index: 100;
		padding: 0.75rem 1rem;
		background: var(--foreground);
		color: var(--background);
		text-decoration: none;
		transform: translateY(-160%);
		transition: transform 100ms linear;
		border-radius: 999px;
	}

	.skip-link:focus-visible {
		transform: translateY(0);
	}

	.shared-header {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-top: 0.25rem;
	}

	.shared-header-actions {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.shared-brand {
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		text-decoration: none;
	}

	.brand-logo {
		height: 48px;
		width: auto;
		display: block;
	}

	/* Light mode: show black logo */
	:root[data-theme='light'] .brand-logo-light { display: none; }
	:root[data-theme='light'] .brand-logo-dark  { display: block; }

	/* Dark mode: show white logo */
	:root[data-theme='dark'] .brand-logo-dark  { display: none; }
	:root[data-theme='dark'] .brand-logo-light { display: block; }

	/* Fallback before JS runs — use system preference */
	@media (prefers-color-scheme: dark) {
		:root:not([data-theme='light']) .brand-logo-dark  { display: none; }
		:root:not([data-theme='light']) .brand-logo-light { display: block; }
	}
	@media (prefers-color-scheme: light) {
		:root:not([data-theme='dark']) .brand-logo-light { display: none; }
		:root:not([data-theme='dark']) .brand-logo-dark  { display: block; }
	}

	.shared-nav {
		display: flex;
		flex-wrap: wrap;
		gap: 2rem;
	}

	.shared-nav-mobile {
		display: none;
		margin-left: auto;
		position: relative;
	}

	.shared-nav a {
		min-height: 44px;
		display: inline-flex;
		align-items: center;
		padding: 0.2rem 0.6rem;
		border-radius: 0.4rem;
		font-size: 0.95rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		text-decoration: none;
		transition: color 120ms ease, background-color 120ms ease;
	}

	.shared-nav a[aria-current='page'] {
		background: var(--page-accent);
		color: #1a1a1a;
	}

	.shared-menu {
		position: relative;
		padding-bottom: 0.45rem;
		margin-bottom: -0.45rem;
	}

	.shared-menu-trigger {
		list-style: none;
		min-height: 44px;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		cursor: pointer;
		padding: 0;
		font-size: 0.95rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		color: var(--foreground);
		text-decoration: none;
		transition: opacity 120ms ease;
	}

	.shared-nav-toggle::-webkit-details-marker,
	.shared-mobile-submenu-trigger::-webkit-details-marker {
		display: none;
	}

	.shared-menu-trigger img {
		filter: var(--icon-filter);
		transition: transform 140ms ease;
	}

	.shared-menu:hover .shared-menu-trigger img,
	.shared-menu:focus-within .shared-menu-trigger img {
		transform: rotate(180deg);
	}

	.shared-nav a:hover,
	.shared-menu-trigger:hover {
		background: var(--page-accent);
		color: #1a1a1a;
		opacity: 1;
	}

	.shared-nav a:focus-visible,
	.shared-menu-trigger:focus-visible {
		background: var(--page-accent);
		color: #1a1a1a;
		opacity: 1;
	}

	.shared-menu-panel {
		position: absolute;
		top: calc(100% - 0.1rem);
		right: 0;
		min-width: 15rem;
		padding: 0.55rem;
		display: none;
		gap: 0.15rem;
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: 0.9rem;
		box-shadow: var(--shadow-soft);
		z-index: 20;
	}

	.shared-menu:hover .shared-menu-panel,
	.shared-menu:focus-within .shared-menu-panel {
		display: grid;
	}

	.shared-menu-panel a {
		min-height: 40px;
		display: flex;
		align-items: center;
		padding: 0.4rem 0.6rem;
		border-radius: 0.65rem;
		font-size: 0.95rem;
		font-weight: 600;
		text-decoration: none;
		transition: background-color 120ms ease;
	}

	.shared-menu-panel a:hover,
	.shared-menu-panel a:focus-visible {
		background: var(--muted);
		text-decoration: none;
	}

	.shared-nav-toggle {
		list-style: none;
		min-height: 44px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.35rem 0;
		cursor: pointer;
	}

	.shared-theme-toggle {
		width: 44px;
		height: 44px;
		display: inline-grid;
		place-items: center;
		border: 1px solid var(--control-border);
		border-radius: 50%;
		color: var(--foreground);
		cursor: pointer;
		transition:
			background-color 120ms ease,
			border-color 120ms ease,
			transform 120ms ease;
	}

	.shared-theme-toggle:hover,
	.shared-theme-toggle:focus-visible {
		background: var(--muted);
		border-color: var(--accent);
		color: var(--accent);
		transform: translateY(-1px);
	}

	.shared-theme-toggle-icons {
		position: relative;
		width: 1.2rem;
		height: 1.2rem;
		display: inline-grid;
		place-items: center;
	}

	.shared-theme-icon {
		position: absolute;
		width: 1.2rem;
		height: 1.2rem;
		transition:
			opacity 160ms ease,
			transform 160ms ease;
	}

	.shared-theme-icon-sun {
		opacity: 1;
		transform: scale(1) rotate(0deg);
	}

	.shared-theme-icon-moon {
		opacity: 0;
		transform: scale(0.7) rotate(-20deg);
	}

	:root[data-theme='dark'] .shared-theme-icon-sun {
		opacity: 0;
		transform: scale(0.7) rotate(20deg);
	}

	:root[data-theme='dark'] .shared-theme-icon-moon {
		opacity: 1;
		transform: scale(1) rotate(0deg);
	}

	.shared-nav-toggle-box {
		display: inline-grid;
		gap: 0.22rem;
	}

	.shared-nav-toggle-box span {
		width: 1.1rem;
		height: 2px;
		background: var(--foreground);
		border-radius: 999px;
		transition: transform 140ms ease, opacity 140ms ease;
	}

	.shared-nav-mobile[open] .shared-nav-toggle-box span:nth-child(1) {
		transform: translateY(6px) rotate(45deg);
	}

	.shared-nav-mobile[open] .shared-nav-toggle-box span:nth-child(2) {
		opacity: 0;
	}

	.shared-nav-mobile[open] .shared-nav-toggle-box span:nth-child(3) {
		transform: translateY(-6px) rotate(-45deg);
	}

	.shared-mobile-panel {
		margin-top: 0.9rem;
		width: min(18rem, calc(100vw - 1.5rem));
		padding: 0.85rem;
		display: grid;
		gap: 0.35rem;
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: 1rem;
		box-shadow: var(--shadow-soft);
	}

	.shared-mobile-panel a,
	.shared-mobile-submenu-trigger {
		min-height: 44px;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.5rem 0.65rem;
		border-radius: 0.75rem;
		font-size: 0.98rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		text-decoration: none;
	}

	.shared-mobile-panel a:hover,
	.shared-mobile-panel a:focus-visible,
	.shared-mobile-submenu-trigger:hover,
	.shared-mobile-submenu-trigger:focus-visible {
		background: var(--page-accent);
		color: #1a1a1a;
	}

	.shared-mobile-submenu-trigger {
		list-style: none;
		cursor: pointer;
	}

	.shared-mobile-submenu-trigger img {
		filter: var(--icon-filter);
		transition: transform 140ms ease;
	}

	.shared-mobile-submenu[open] .shared-mobile-submenu-trigger img {
		transform: rotate(180deg);
	}

	.shared-mobile-submenu-panel {
		padding-top: 0.2rem;
		display: grid;
		gap: 0.2rem;
	}

	.shared-mobile-submenu-panel a {
		padding-left: 1rem;
	}

	.display-title {
		width: 100%;
		max-width: none;
		margin: 1rem 0 0;
		font-size: clamp(3rem, 4.8vw, 5rem);
		line-height: 1.02;
		letter-spacing: -0.05em;
		font-weight: 800;
		color: var(--foreground);
	}

	.shared-footer {
		padding: 0 0 3rem;
	}

	.shared-footer-inner {
		width: min(calc(100% - 12rem), 64rem);
		margin: 0 auto;
		padding-top: 1.5rem;
		border-top: 1px solid var(--border);
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		flex-wrap: wrap;
	}

	.shared-footer-left {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.footer-brand {
		display: inline-block;
		text-decoration: none;
	}

	.footer-logo {
		height: 22px;
		width: auto;
		display: block;
	}

	.shared-footer-links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.shared-footer-links a {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--foreground);
		text-decoration: none;
	}

	.shared-footer-links a:hover {
		color: var(--accent);
		text-decoration: underline;
	}

	.shared-footer-copy {
		font-size: 0.82rem;
		color: var(--muted-foreground);
		margin: 0;
	}

	.footer-liu {
		display: flex;
		align-items: center;
	}

	.liu-logo {
		height: 40px;
		width: auto;
	}

/* Background blobs */
	.bg-blob {
		position: fixed;
		border-radius: 50%;
		pointer-events: none;
		z-index: -1;
		opacity: 0.06;
		will-change: transform;
		filter: blur(60px);
	}

	/* Entrance animations */
	.animate-up {
		opacity: 0;
		transform: translateY(28px);
		transition: opacity 550ms ease, transform 550ms ease;
		transition-delay: var(--delay, 0ms);
	}
	.animate-up.in-view {
		opacity: 1;
		transform: none;
	}

	/* Hero float */
	@keyframes float {
		0%, 100% { transform: translateY(0px); }
		50%       { transform: translateY(-10px); }
	}

@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}

		*,
		*::before,
		*::after {
			animation: none !important;
			transition-duration: 0ms !important;
		}
	}

	@media (max-width: 920px) {
		.shared-header {
			gap: 0.75rem;
			align-items: center;
			justify-content: space-between;
			flex-wrap: nowrap;
		}

		.shared-header-actions {
			margin-left: auto;
		}

		.shared-nav-desktop {
			display: none;
		}

		.shared-nav-mobile {
			display: block;
		}

		.shared-nav-mobile[open] .shared-nav-toggle {
			margin-left: auto;
		}

		.shared-nav-mobile[open] .shared-mobile-panel {
			position: absolute;
			top: calc(100% + 0.75rem);
			right: 0;
			margin-left: 0;
			z-index: 30;
